# -----------------------------------------------------------------------------
# rcc-scripts.conf — Build configuration
# Copy this file to your project root (sibling to rcc-scripts/) and rename
# to rcc-scripts.conf. Edit the values to match your project.
#
# All values are sourced directly by Bash, so the format is:
#   KEY="value"
# Strings only, no arrays or nested structures.
# -----------------------------------------------------------------------------

# --- Project metadata -------------------------------------------------------

PROJECT_NAME="changethis"
PROJECT_DESCRIPTION=""
PROJECT_MAINTAINER=""
PROJECT_VENDOR=""
PROJECT_HOMEPAGE=""
PROJECT_LICENSE="MIT"

# --- Build directories (relative to project root) ---------------------------

BUILD_DIST_DIR="dist"
BUILD_TARGET_DIR="target"

# --- Linux packaging (nfpm) -------------------------------------------------

LINUX_DEB_SECTION="default"
LINUX_DEB_PRIORITY="extra"
LINUX_RPM_GROUP="Development/Tools"
LINUX_ARCHLINUX_CATEGORY="utils"

# --- Tool versions ----------------------------------------------------------

ZIG_VERSION="0.14.0"
NFPM_VERSION="2.34.2"
